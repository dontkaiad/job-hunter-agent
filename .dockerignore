# Keep the image lean and NEVER bake secrets / personal data / local state.
# (The build context copies everything except these.)

# Secrets & personal data — must live on the HOST and be bind-mounted, never
# baked into the image.
.env
.env.*
!.env.example
config/profile.local.yaml

# Local SQLite DB(s) and Telegram session files — host-mounted / regenerated.
*.db
*.session
*.session-journal
data/

# Virtualenv / VCS / caches / tests — not needed at runtime, bloat the image.
.venv
.git
.gitignore
__pycache__/
*.py[codz]
.pytest_cache/
.mypy_cache/
.ruff_cache/
tests/
.claude/

# Frontend (issue #6): SHIP the frontend/ SOURCE to the build context so the
# node build stage can `npm ci` + `npm run build` it. EXCLUDE node_modules
# (installed fresh inside the node stage) and dist (built in-stage and copied
# from the node stage, never from the host) so they neither bloat the context
# nor clobber the in-stage build.
frontend/node_modules/
frontend/dist/
