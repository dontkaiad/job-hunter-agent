# ---------------------------------------------------------------------------
# job-hunter-agent — environment configuration
# Copy this file to .env and fill in real values. NEVER commit .env.
# All values are loaded via python-dotenv. No secret is hardcoded in code.
# ---------------------------------------------------------------------------

# --- Anthropic (LLM: extract, relevance score, research, draft) ---
# Get a key at https://console.anthropic.com/ -> API Keys
ANTHROPIC_API_KEY=
# Model routing (the model id is chosen PER STEP):
#   ANTHROPIC_CHEAP_MODEL = bulk/cheap steps: extraction, research, draft (Haiku).
#   ANTHROPIC_JUDGE_MODEL = judgment/scoring step: rubric relevance score (Sonnet).
# Both are optional; sensible defaults below. ANTHROPIC_MODEL is kept as a
# back-compat alias for the cheap model.
ANTHROPIC_CHEAP_MODEL=claude-haiku-4-5
ANTHROPIC_JUDGE_MODEL=claude-sonnet-4-6
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Ingestion mode ---
# How posts are read from Telegram channels:
#   web      = PRIMARY/DEFAULT. Fetches the public preview at
#              https://t.me/s/<channel> over plain HTTP. Requires NO auth
#              (no api_id/hash/session, no login). This is the default.
#   telethon = OPTIONAL fallback userbot. Requires the TELEGRAM_API_* values
#              below. Only use this if you deliberately want a userbot.
# Leave empty for the default ("web").
INGEST_MODE=web

# --- Source channels (REQUIRED for both ingestion modes) ---
# Comma-separated public channel usernames (the system reads t.me/s/<name>).
# e.g. @somechannel,@another  (also accepts plain names or t.me links).
# Note: only PUBLIC channels are readable via the web reader.
TELEGRAM_CHANNELS=

# --- Telegram userbot ingestion (Telethon) -- OPTIONAL ---
# ONLY needed when INGEST_MODE=telethon. Leave ALL of these empty for the
# default web ingestion, which needs no Telegram authentication.
# Create an app at https://my.telegram.org/apps to obtain api_id and api_hash.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Session: either a StringSession value, or a session file name (default below).
# To generate a StringSession run: python -m job_hunter.ingest_telegram --login
TELEGRAM_SESSION=
# Fallback on-disk session file name (used when TELEGRAM_SESSION is empty).
TELEGRAM_SESSION_NAME=job_hunter
# How many recent messages to pull per channel on each Telethon ingest run.
# (The web reader returns whatever the public preview page contains.)
TELEGRAM_FETCH_LIMIT=50

# --- aiogram notification bot (HITL surface) ---
# Used by BOTH `python -m job_hunter.run` (delivers surfaced cards, one-shot)
# and `python -m job_hunter.serve` (long-running; receives the button taps and
# drives advance()). They share the PostgreSQL DB below, so no extra key is needed
# for serve. Approve -> research -> draft additionally needs ANTHROPIC_API_KEY.
# Create a bot via @BotFather to get the token.
BOT_TOKEN=
# Numeric chat id that receives surfaced jobs and approval buttons.
# Message @userinfobot from the target chat to find it.
NOTIFY_CHAT_ID=

# --- Ops logging (OPTIONAL) ---
# A SEPARATE "ops" Telegram bot/chat/topic that receives lifecycle pings
# (startup) and error notifications, via a raw Bot API call (not the operator
# bot above). All three are OPTIONAL: if TG_LOG_BOT_TOKEN or TG_LOG_CHAT_ID is
# empty, ops logging is silently disabled (no-op, never crashes). The thread id
# is optional (omit to post to the chat's General topic).
#   TG_LOG_BOT_TOKEN        — ops bot token (from @BotFather)
#   TG_LOG_CHAT_ID          — ops chat / supergroup id (e.g. -1001234567890)
#   TG_LOG_THREAD_JOBHUNTER — ops topic thread id for jobhunter (e.g. 30)
# TG_LOG_BOT_TOKEN=
# TG_LOG_CHAT_ID=
# TG_LOG_THREAD_JOBHUNTER=

# --- Bot access control (allowlist) ---
# Comma-separated Telegram USER ids allowed to interact with the bot (press
# buttons / send messages). Any update from a user NOT in this list is dropped
# silently: no handler runs, no LLM call, no token use, no state change.
# Get your user id from @userinfobot.
#   e.g. ALLOWED_USER_IDS=11111111,22222222
# DEFAULT: if left empty, the allowlist falls back to {NOTIFY_CHAT_ID}.
# FAIL CLOSED: if BOTH ALLOWED_USER_IDS and NOTIFY_CHAT_ID are empty, the
# allowlist is empty and the bot ignores EVERYONE (it is never wide open).
ALLOWED_USER_IDS=

# --- Storage (PostgreSQL) ---
# The app connects to PostgreSQL via DATABASE_URL (psycopg v3). Format:
#   postgresql://USER:PASSWORD@HOST:5432/DBNAME
#
# Postgres is NOT bundled in docker-compose: the app uses an EXISTING shared
# Postgres (container "nexus-arcana-db") reached over the external
# "nexus-arcana_default" network. HOST must be that container name, and
# USER/PASSWORD/DBNAME must be a role+database that already exist on it.
DATABASE_URL=postgresql://jobhunter:jobhunter@nexus-arcana-db:5432/jobhunter
#
# For a LOCAL (non-Docker) run against a Postgres on your machine, use:
#   DATABASE_URL=postgresql://jobhunter:jobhunter@127.0.0.1:5432/jobhunter

# --- Scheduling / timezone (serve's daily harvest) ---
# `python -m job_hunter.serve` runs aiogram polling AND a SINGLE daily harvest
# (the same ingest->score->notify path as `python -m job_hunter.run`) at 10:00
# LOCAL time. The two vars below control "local":
#
# SCHEDULE_TZ — IANA timezone name the scheduler's 10:00 cron trigger uses, e.g.
#   Europe/Belgrade. The harvest fires at 10:00 in THIS zone. If LEFT EMPTY it
#   falls back to the system local timezone (it is NEVER hardcoded to UTC). It
#   affects the trigger ONLY; stored timestamps are always UTC.
SCHEDULE_TZ=Europe/Belgrade
#
# TZ — the CONTAINER OS clock timezone (Docker only). Set it to the SAME value
#   as SCHEDULE_TZ so the container's wall clock and the harvest trigger agree.
#   Ignored for a local run (your OS clock is already set).
TZ=Europe/Belgrade

# --- Dashboard auth (issue #5): Telegram-Login-Widget + cross-subdomain SSO ---
# The dashboard FastAPI (job_hunter/webapi.py) gates EVERY /api route behind a
# Telegram login + grants-based authorization. These values configure it.
#
# TG_LOGIN_BOT_TOKEN — token of the LOGIN bot (the log-bot) that SIGNS the
#   Telegram Login Widget. verify_login_widget uses THIS token. Operator note:
#   this is expected to be the l4rk_sys_bot token (CONFIRM separately). Never
#   commit a real token.
TG_LOGIN_BOT_TOKEN=
# TG_LOGIN_BOT_USERNAME — the USERNAME (no @) of that same login bot, used by
#   the widget's data-telegram-login attribute on the /login page. The bot's
#   domain must be registered with @BotFather /setdomain for the widget to load.
TG_LOGIN_BOT_USERNAME=
# SESSION_SECRET — the signing key for the session cookie. Use the SAME value
#   across ALL heylark apps (job-hunter, Nexus, Arcana): the shared secret is
#   what makes the cookie a single-sign-on token. Generate a long random string
#   (e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`).
SESSION_SECRET=
# COOKIE_DOMAIN — cookie Domain so the session is shared across subdomains.
#   Default ".heylark.dev" (note the leading dot).
COOKIE_DOMAIN=.heylark.dev
# SUPERUSER_TG_IDS — comma-separated Telegram user ids that are ALWAYS allowed
#   (no grant row needed) for every app. e.g. 67686090,790273371
SUPERUSER_TG_IDS=
# AUTH_DATABASE_URL — DSN of the SHARED auth Postgres holding the grants table.
#   SEPARATE database from DATABASE_URL above.
#   Format: postgresql://USER:PASSWORD@HOST:5432/DBNAME
AUTH_DATABASE_URL=
# DASHBOARD_PUBLIC_URL — the public https origin of the dashboard
#   (e.g. https://jobs.heylark.dev). Used to render the Telegram Login Widget's
#   ABSOLUTE data-auth-url on the /login page. REQUIRED for MOBILE login: the
#   mobile oauth.telegram.org flow needs an absolute callback URL (desktop
#   resolves a relative one against the page origin, but mobile errors on it).
#   Behind a reverse proxy (Caddy) the container only sees http://127.0.0.1:8001,
#   so the request host is WRONG — this MUST be set explicitly. If left empty the
#   /login page falls back to the relative "/auth/callback" (desktop/local only).
DASHBOARD_PUBLIC_URL=

# --- FX (no-key live rates) ---
# Provider: "frankfurter" (frankfurter.app) or "erapi" (open.er-api.com).
FX_PROVIDER=frankfurter
# Cache TTL for FX rates, in seconds (default 24h).
FX_CACHE_TTL=86400

# --- Ingestion date window ---
# For a NEW channel (no stored watermark) ingest posts from the last N days.
# After the first run, only posts NEWER than the per-channel watermark are
# ingested (stored in the channel_state table).
NEW_CHANNEL_LOOKBACK_DAYS=14

# --- Candidate profile (NOT an env var — a YAML file) ---
# The candidate's personal profile (role, grade, hands-on / in-development
# skills, stack, languages, location priority, gender for self-reference, the
# EUR/month salary floor, and the GitHub + resume draft signature) is loaded
# from a YAML file, NOT from this .env:
#   config/profile.local.yaml   (your REAL profile — GITIGNORED, never committed)
#   config/profile.example.yaml (generic fallback shipped in the repo)
# To run the bot for yourself: copy config/profile.example.yaml to
# config/profile.local.yaml and fill in your details. The salary floor and the
# draft signature come from that profile, so they are intentionally NOT here.
