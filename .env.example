# ---------------------------------------------------------------------------
# job-hunter-agent — environment configuration
# Copy this file to .env and fill in real values. NEVER commit .env.
# All values are loaded via python-dotenv. No secret is hardcoded in code.
# ---------------------------------------------------------------------------

# --- Anthropic (LLM: extract, relevance score, research, draft) ---
# Get a key at https://console.anthropic.com/ -> API Keys
ANTHROPIC_API_KEY=
# Model routing (the model id is chosen PER STEP):
#   ANTHROPIC_CHEAP_MODEL = bulk/cheap steps: extraction, research, draft (Haiku).
#   ANTHROPIC_JUDGE_MODEL = judgment/scoring step: rubric relevance score (Sonnet).
# Both are optional; sensible defaults below. ANTHROPIC_MODEL is kept as a
# back-compat alias for the cheap model.
ANTHROPIC_CHEAP_MODEL=claude-haiku-4-5
ANTHROPIC_JUDGE_MODEL=claude-sonnet-4-6
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Ingestion mode ---
# How posts are read from Telegram channels:
#   web      = PRIMARY/DEFAULT. Fetches the public preview at
#              https://t.me/s/<channel> over plain HTTP. Requires NO auth
#              (no api_id/hash/session, no login). This is the default.
#   telethon = OPTIONAL fallback userbot. Requires the TELEGRAM_API_* values
#              below. Only use this if you deliberately want a userbot.
# Leave empty for the default ("web").
INGEST_MODE=web

# --- Source channels (REQUIRED for both ingestion modes) ---
# Comma-separated public channel usernames (the system reads t.me/s/<name>).
# e.g. @somechannel,@another  (also accepts plain names or t.me links).
# Note: only PUBLIC channels are readable via the web reader.
TELEGRAM_CHANNELS=

# --- Telegram userbot ingestion (Telethon) -- OPTIONAL ---
# ONLY needed when INGEST_MODE=telethon. Leave ALL of these empty for the
# default web ingestion, which needs no Telegram authentication.
# Create an app at https://my.telegram.org/apps to obtain api_id and api_hash.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Session: either a StringSession value, or a session file name (default below).
# To generate a StringSession run: python -m job_hunter.ingest_telegram --login
TELEGRAM_SESSION=
# Fallback on-disk session file name (used when TELEGRAM_SESSION is empty).
TELEGRAM_SESSION_NAME=job_hunter
# How many recent messages to pull per channel on each Telethon ingest run.
# (The web reader returns whatever the public preview page contains.)
TELEGRAM_FETCH_LIMIT=50

# --- aiogram notification bot (HITL surface) ---
# Used by BOTH `python -m job_hunter.run` (delivers surfaced cards, one-shot)
# and `python -m job_hunter.serve` (long-running; receives the button taps and
# drives advance()). They share the SQLite DB below, so no extra key is needed
# for serve. Approve -> research -> draft additionally needs ANTHROPIC_API_KEY.
# Create a bot via @BotFather to get the token.
BOT_TOKEN=
# Numeric chat id that receives surfaced jobs and approval buttons.
# Message @userinfobot from the target chat to find it.
NOTIFY_CHAT_ID=

# --- Bot access control (allowlist) ---
# Comma-separated Telegram USER ids allowed to interact with the bot (press
# buttons / send messages). Any update from a user NOT in this list is dropped
# silently: no handler runs, no LLM call, no token use, no state change.
# Get your user id from @userinfobot.
#   e.g. ALLOWED_USER_IDS=11111111,22222222
# DEFAULT: if left empty, the allowlist falls back to {NOTIFY_CHAT_ID}.
# FAIL CLOSED: if BOTH ALLOWED_USER_IDS and NOTIFY_CHAT_ID are empty, the
# allowlist is empty and the bot ignores EVERYONE (it is never wide open).
ALLOWED_USER_IDS=

# --- Storage ---
# Path to the SQLite database file.
DB_PATH=job_hunter.db

# --- FX (no-key live rates) ---
# Provider: "frankfurter" (frankfurter.app) or "erapi" (open.er-api.com).
FX_PROVIDER=frankfurter
# Cache TTL for FX rates, in seconds (default 24h).
FX_CACHE_TTL=86400

# --- Ingestion date window ---
# For a NEW channel (no stored watermark) ingest posts from the last N days.
# After the first run, only posts NEWER than the per-channel watermark are
# ingested (stored in the channel_state table).
NEW_CHANNEL_LOOKBACK_DAYS=14

# --- Candidate profile (NOT an env var — a YAML file) ---
# The candidate's personal profile (role, grade, hands-on / in-development
# skills, stack, languages, location priority, gender for self-reference, the
# EUR/month salary floor, and the GitHub + resume draft signature) is loaded
# from a YAML file, NOT from this .env:
#   config/profile.local.yaml   (your REAL profile — GITIGNORED, never committed)
#   config/profile.example.yaml (generic fallback shipped in the repo)
# To run the bot for yourself: copy config/profile.example.yaml to
# config/profile.local.yaml and fill in your details. The salary floor and the
# draft signature come from that profile, so they are intentionally NOT here.
